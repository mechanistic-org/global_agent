# EN-OS Operator Environment
# Copy this file to .env (gitignored) and fill in your secrets.

# ── GitHub Webhook Daemon (#73) ────────────────────────────────────────────
# Set in: GitHub repo Settings > Webhooks > Secret
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Port for the webhook daemon (default 8001; FastMCP SSE runs on 8000)
WEBHOOK_DAEMON_PORT=8001

# Set to true ONLY when nanoclaw:latest Docker image is built (#61)
NANOCLAW_ENABLED=false

# ── Google / Gemini ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# ── Cloudflare R2 ──────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_here
R2_SECRET_ACCESS_KEY=your_r2_secret_here
